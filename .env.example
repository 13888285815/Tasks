# =============================================
# 智能客服 Agent - 环境变量配置
# 复制为 .env 并填写实际值（.env 已被 .gitignore 忽略）
# =============================================

# --------- 服务配置 ---------
PORT=3000
NODE_ENV=development   # production | development

# --------- 加密密钥（32字节 hex，64位字符）---------
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 生产环境必须设置，否则启动失败！
ENCRYPT_KEY=your_64_char_hex_key_here

# --------- Session 密钥 ---------
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 生产环境必须设置，否则启动失败！
SESSION_SECRET=your_session_secret_here

# --------- 管理员账号 ---------
ADMIN_USER=admin
# 推荐使用 bcrypt hash（避免明文密码在环境变量中）
# 生成命令：node -e "console.log(require('bcryptjs').hashSync('your_password', 12))"
ADMIN_PASS_HASH=$2b$12$your_bcrypt_hash_here
# 开发环境可以直接设置明文（生产不推荐）
# ADMIN_PASS=admin888

# --------- CORS 白名单（逗号分隔）---------
# CORS_ORIGINS=https://your-domain.com,https://admin.your-domain.com
